(module 'tests 'integration 'accessors)
(define (host-int) external)
(define (host-float) external)
(define (host-bool) external)
(define (host-string) external)
(define (host-symbol) external)
(define (host-list) external)
(define (host-object) external)
(define (host-check i f b s sym lst) external)
(state (start)
  (steps
    (let checked (host-check
                   (host-int)
                   (host-float)
                   (host-bool)
                   (host-string)
                   (host-symbol)
                   (host-list)))
    (transition end (concat checked ":" (json (host-object))))))
