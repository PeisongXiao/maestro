(module tests integration main)
(import tests integration lib suffix)
(define worker (import-program tests integration worker))
(define (host-object) external)
(state (start)
  (steps
    (let obj (host-object))
    (let payload {"kind":"bundle","seen":(list (get obj user name) (get obj user meta active))})
    (let via-run (run worker payload))
    (transition end (suffix via-run))))
